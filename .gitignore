*.egg
MANIFEST

# --- Machine Learning / Deep Learning Weights & Data Artifacts ---
# PyTorch, TensorFlow, and general ML model weights (often too large for Git)
*.pth
*.ckpt
*.h5
*.pb
*.onnx
*.joblib
*.pkl
*.pickle

# Large data/results in artifacts directory, but keep configurations if needed
# Note: If you want to commit specific JSON configurations, you can keep them unignored:
# !artifacts/*.json

# --- Streamlit Configurations & Secrets ---
.streamlit/secrets.toml

# --- Environment Variables, Credentials, and Secrets ---
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.passwd

# --- IDE and Editor Configurations ---
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# PyCharm / IntelliJ
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*~
*.swp
*.swo
